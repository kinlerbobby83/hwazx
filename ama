function AmazonUI:CreateWatermark()
    self.watermarkFrame = Utility:Create("Frame", {
        Size = UDim2.new(0, 180, 0, 24),
        Position = UDim2.new(0, 10, 1, -34),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.6,
        Visible = self.config.watermarkEnabled
    }, self.mainFrame)
    
    Utility:Create("UICorner", {CornerRadius = UDim.new(0, 12)}, self.watermarkFrame)
    
    self.watermarkText = Utility:Create("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "FPS: 0 | Ping: 0 | Time: --:--:--",
        TextColor3 = Color3.fromRGB(200, 200, 200),
        TextSize = 11,
        Font = Enum.Font.Gotham
    }, self.watermarkFrame)
    
    task.spawn(function()
        local lastTime = tick()
        local frameCount = 0
        while self.watermarkFrame and self.watermarkFrame.Parent do
            frameCount = frameCount + 1
            local now = tick()
            if now - lastTime >= 1 then
                local fps = frameCount
                frameCount = 0
                lastTime = now
                
                local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() or 0)
                local timeString = os.date("%H:%M:%S")
                
                self.watermarkText.Text = string.format("FPS: %d | Ping: %dms | Time: %s", fps, ping, timeString)
            end
            task.wait()
        end
    end)
end

function AmazonUI:CreateFloatingButtons()
    local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled
    
    -- Toggle UI Button
    self.toggleButton = Utility:Create("TextButton", {
        Size = UDim2.new(0, 50, 0, 50),
        Position = UDim2.new(1, -60, 0, 100),
        BackgroundColor3 = Color3.fromRGB(230, 126, 34),
        Text = "UI",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        Visible = isMobile
    }, self.mainFrame)
    
    Utility:Create("UICorner", {CornerRadius = UDim.new(1, 0)}, self.toggleButton)
    
    -- Lock Button
    self.lockButton = Utility:Create("TextButton", {
        Size = UDim2.new(0, 50, 0, 50),
        Position = UDim2.new(1, -60, 0, 160),
        BackgroundColor3 = Color3.fromRGB(60, 65, 70),
        Text = "🔒",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 20,
        BorderSizePixel = 0,
        Visible = isMobile
    }, self.mainFrame)
    
    Utility:Create("UICorner", {CornerRadius = UDim.new(1, 0)}, self.lockButton)
    
    local windowVisible = true
    local draggableEnabled = true
    
    self.toggleButton.MouseButton1Click:Connect(function()
        windowVisible = not windowVisible
        self.window.Visible = windowVisible
        self.toggleButton.BackgroundColor3 = windowVisible and Color3.fromRGB(230, 126, 34) or Color3.fromRGB(100, 100, 100)
    end)
    
    self.lockButton.MouseButton1Click:Connect(function()
        draggableEnabled = not draggableEnabled
        self.lockButton.Text = draggableEnabled and "🔓" or "🔒"
        self.lockButton.BackgroundColor3 = draggableEnabled and Color3.fromRGB(60, 65, 70) or Color3.fromRGB(230, 126, 34)
    end)
end

function AmazonUI:SetupMobileDetection()
    local function handleResize()
        local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled
        local screenSize = UserInputService:GetScreenSize()
        
        if isMobile then
            self.window.Size = UDim2.new(0.92, 0, 0.75, 0)
            self.window.Position = UDim2.new(0.04, 0, 0.125, 0)
            self.sidebar.Size = UDim2.new(0, 160, 1, -60)
            self.contentArea.Size = UDim2.new(1, -160, 1, -60)
            self.contentArea.Position = UDim2.new(0, 160, 0, 60)
            self.searchBox.Size = UDim2.new(0, 200, 0, 36)
            self.toggleButton.Visible = true
            self.lockButton.Visible = true
        else
            self.toggleButton.Visible = false
            self.lockButton.Visible = false
        end
    end
    
    UserInputService:GetPropertyChangedSignal("TouchEnabled"):Connect(handleResize)
    UserInputService:GetPropertyChangedSignal("MouseEnabled"):Connect(handleResize)
    handleResize()
end

function AmazonUI:SetupSearchFilter()
    local function filterContent(searchTerm)
        searchTerm = searchTerm:lower()
        for _, child in ipairs(self.contentArea:GetChildren()) do
            if child:IsA("Frame") and child.Name == "SectionCard" then
                local found = searchTerm == "" or child:FindFirstChild("Title") and child.Title.Text:lower():find(searchTerm)
                child.Visible = found
                if found then
                    for _, component in ipairs(child:GetChildren()) do
                        if component:IsA("Frame") and component.Name ~= "Title" then
                            component.Visible = true
                        end
                    end
                end
            end
        end
    end
    
    self.searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        filterContent(self.searchBox.Text)
    end)
end

function AmazonUI:CreateSection(title)
    local section = Utility:Create("Frame", {
        Name = "SectionCard",
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Color3.fromRGB(30, 34, 39),
        BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y
    }, self.contentArea)
    
    Utility:Create("UICorner", {CornerRadius = UDim.new(0, 8)}, section)
    Utility:Create("UIStroke", {Color = Color3.fromRGB(40, 45, 50), Thickness = 1}, section)
    
    local titleLabel = Utility:Create("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, -24, 0, 36),
        Position = UDim2.new(0, 12, 0, 8),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Color3.fromRGB(230, 126, 34),
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left
    }, section)
    
    local contentContainer = Utility:Create("Frame", {
        Size = UDim2.new(1, -24, 0, 0),
        Position = UDim2.new(0, 12, 0, 48),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y
    }, section)
    
    local listLayout = Utility:Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 12)
    }, contentContainer)
    
    return {
        container = contentContainer,
        addComponent = function(componentFunc, ...)
            return componentFunc(contentContainer, ...)
        end
    }
end

function AmazonUI:AddTab(name, icon)
    local tabButton = Utility:Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundColor3 = Color3.fromRGB(27, 31, 36),
        Text = "  " .. name,
        TextColor3 = Color3.fromRGB(200, 200, 200),
        TextSize = 14,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        BorderSizePixel = 0
    }, self.sidebar)
    
    local hoverTween = TweenService:Create(tabButton, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 39, 44)})
    tabButton.MouseEnter:Connect(function() hoverTween:Play() end)
    tabButton.MouseLeave:Connect(function()
        if self.activeTab ~= tabButton then
            TweenService:Create(tabButton, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(27, 31, 36)}):Play()
        end
    end)
    
    local sectionGroup = {}
    
    tabButton.MouseButton1Click:Connect(function()
        if self.activeTab then
            TweenService:Create(self.activeTab, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(27, 31, 36), TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
        end
        self.activeTab = tabButton
        TweenService:Create(tabButton, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(230, 126, 34), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        
        for _, section in pairs(sectionGroup) do
            section.container.Parent = self.contentArea
        end
        for _, other in pairs(self.sections or {}) do
            if other ~= sectionGroup then
                for _, section in pairs(other) do
                    section.container.Parent = nil
                end
            end
        end
    end)
    
    self.sections = self.sections or {}
    table.insert(self.sections, sectionGroup)
    
    return {
        createSection = function(title)
            local section = self:CreateSection(title)
            table.insert(sectionGroup, section)
            return section
        end
    }
end

function AmazonUI:ShowNotification(title, message, duration, type)
    NotificationSystem:Show(title, message, duration, type)
end

