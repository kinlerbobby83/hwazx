function Components:Keybind(parent, labelText, defaultKey, callback)
    local frame = Utility:Create("Frame", {
        Size = UDim2.new(0, 200, 0, 36),
        BackgroundTransparency = 1
    }, parent)
    
    local label = Utility:Create("TextLabel", {
        Size = UDim2.new(0, 100, 1, 0),
        BackgroundTransparency = 1,
        Text = labelText,
        TextColor3 = Color3.fromRGB(220, 220, 220),
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left
    }, frame)
    
    local keyButton = Utility:Create("TextButton", {
        Size = UDim2.new(0, 80, 1, 0),
        Position = UDim2.new(0, 100, 0, 0),
        BackgroundColor3 = Color3.fromRGB(45, 50, 55),
        Text = defaultKey or "None",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0
    }, frame)
    
    local listening = false
    local currentKey = defaultKey
    
    keyButton.MouseButton1Click:Connect(function()
        listening = true
        keyButton.Text = "..."
        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if listening and not gameProcessed then
                local key = input.KeyCode.Name
                if key ~= "Unknown" then
                    listening = false
                    currentKey = key
                    keyButton.Text = key
                    if callback then callback(key) end
                    connection:Disconnect()
                end
            end
        end)
        task.wait(3)
        if listening then
            listening = false
            keyButton.Text = currentKey or "None"
            connection:Disconnect()
        end
    end)
    
    return {getKey = function() return currentKey end}
end

