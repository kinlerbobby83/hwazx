-- Amazon-style Main UI Class
local AmazonUI = {}
AmazonUI.__index = AmazonUI

function AmazonUI.new()
    local self = setmetatable({}, AmazonUI)
    
    self.config = ConfigSystem:Load()
    ConfigSystem.onChange = function(key, value)
        if key == "watermarkEnabled" and self.watermarkFrame then
            self.watermarkFrame.Visible = value
        end
    end
    
    self:CreateMainFrame()
    self:CreateWatermark()
    self:CreateFloatingButtons()
    self:SetupMobileDetection()
    self:SetupSearchFilter()
    
    NotificationSystem.container = self.mainFrame
    
    return self
end

function AmazonUI:CreateMainFrame()
