-- Utility Functions
local Utility = {}
function Utility:Create(className, properties, parent)
    local obj = Instance.new(className)
    for prop, value in pairs(properties) do
        obj[prop] = value
    end
    obj.Parent = parent or nil
    return obj
end

function Utility:Tween(obj, properties, duration, style, direction)
    local tweenInfo = TweenInfo.new(duration or 0.2, (style or Enum.EasingStyle.Quad), (direction or Enum.EasingDirection.Out))
    local tween = TweenService:Create(obj, tweenInfo, properties)
    tween:Play()
    return tween
end

function Utility:Clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

-- Notification System
local NotificationSystem = {}
local notificationQueue = {}
local activeNotifications = {}

function NotificationSystem:Show(title, message, duration, type)
    type = type or "info"
    local container = self.container
    if not container then return end
    
    local colors = {
        info = Color3.fromRGB(52, 152, 219),
        success = Color3.fromRGB(46, 204, 113),
        warning = Color3.fromRGB(241, 196, 15),
        error = Color3.fromRGB(231, 76, 60)
    }
    
    local notification = Utility:Create("Frame", {
        Size = UDim2.new(0, 320, 0, 70),
        Position = UDim2.new(1, -340, 1, -100),
        BackgroundColor3 = Color3.fromRGB(30, 35, 40),
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        ClipsDescendants = true
    }, container)
    
    local accentBar = Utility:Create("Frame", {
        Size = UDim2.new(0, 4, 1, 0),
        BackgroundColor3 = colors[type],
        BorderSizePixel = 0
    }, notification)
    
    local titleLabel = Utility:Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 12, 0, 8),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left
    }, notification)
    
    local msgLabel = Utility:Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 12, 0, 28),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = Color3.fromRGB(180, 180, 180),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    }, notification)
    
    Utility:Tween(notification, {BackgroundTransparency = 0}, 0.3)
    
    table.insert(activeNotifications, notification)
    local notifId = #activeNotifications
    
    task.wait(duration or 3)
    
    if notification and notification.Parent then
        Utility:Tween(notification, {BackgroundTransparency = 1}, 0.3)
        task.wait(0.3)
        notification:Destroy()
        table.remove(activeNotifications, notifId)
    end
end

-- Config System
local ConfigSystem = {}
local configData = {}
local configFile = "AmazonUI_Settings"

function ConfigSystem:Load()
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(configFile))
    end)
    if success and type(data) == "table" then
        configData = data
    else
        configData = {
            theme = "dark",
            notificationsEnabled = true,
            autoSave = true,
            watermarkEnabled = true,
            sidebarCollapsed = false
        }
    end
    return configData
end

function ConfigSystem:Save()
    local success, err = pcall(function()
        writefile(configFile, HttpService:JSONEncode(configData))
    end)
    if not success then
        warn("Failed to save config:", err)
    end
end

function ConfigSystem:Get(key)
    return configData[key]
end

function ConfigSystem:Set(key, value)
    configData[key] = value
    if configData.autoSave then
        self:Save()
    end
    if self.onChange then
        self.onChange(key, value)
    end
end

-- Draggable Window Manager
local DraggableManager = {}
function DraggableManager:MakeDraggable(frame, dragHandle, onDragStart, onDragEnd)
    local dragging = false
    local dragStartPos = Vector2.new()
    local frameStartPos = frame.Position
    
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStartPos = input.Position
            frameStartPos = frame.Position
            if onDragStart then onDragStart() end
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if onDragEnd then onDragEnd() end
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStartPos
            local newX = frameStartPos.X.Scale + (delta.X / frame.AbsoluteSize.X)
            local newY = frameStartPos.Y.Scale + (delta.Y / frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(newX, 0, newY, 0)
        end
    end)
end

-- Component Classes
local Components = {}

function Components:Button(parent, text, callback, width, height)
    local button = Utility:Create("TextButton", {
        Size = UDim2.new(0, width or 120, 0, height or 36),
        BackgroundColor3 = Color3.fromRGB(45, 50, 55),
        Text = text,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        BorderSizePixel = 0,
        AutoButtonColor = false
    }, parent)
    
    local hoverTween = TweenService:Create(button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(60, 65, 70)})
    local leaveTween = TweenService:Create(button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(45, 50, 55)})
    local clickTween = TweenService:Create(button, TweenInfo.new(0.05), {BackgroundColor3 = Color3.fromRGB(35, 40, 45)})
    
    button.MouseEnter:Connect(function() hoverTween:Play() end)
    button.MouseLeave:Connect(function() leaveTween:Play() end)
    button.MouseButton1Click:Connect(function()
        clickTween:Play()
        clickTween.Completed:Wait()
        leaveTween:Play()
        if callback then callback() end
    end)
    
    return button
end

function Components:Toggle(parent, labelText, defaultState, callback)
    local frame = Utility:Create("Frame", {
        Size = UDim2.new(0, 200, 0, 30),
        BackgroundTransparency = 1
    }, parent)
    
    local label = Utility:Create("TextLabel", {
        Size = UDim2.new(0, 140, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = labelText,
        TextColor3 = Color3.fromRGB(220, 220, 220),
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left
    }, frame)
    
    local toggleBg = Utility:Create("Frame", {
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -44, 0, 5),
        BackgroundColor3 = defaultState and Color3.fromRGB(230, 126, 34) or Color3.fromRGB(70, 75, 80),
        BorderSizePixel = 0
    }, frame)
    
    local toggleKnob = Utility:Create("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = defaultState and UDim2.new(1, -18, 0, 2) or UDim2.new(0, 2, 0, 2),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0
    }, toggleBg)
    
    local state = defaultState
    
    local function updateToggle(newState)
        state = newState
        local targetColor = state and Color3.fromRGB(230, 126, 34) or Color3.fromRGB(70, 75, 80)
        local targetPos = state and UDim2.new(1, -18, 0, 2) or UDim2.new(0, 2, 0, 2)
        Utility:Tween(toggleBg, {BackgroundColor3 = targetColor}, 0.2)
        Utility:Tween(toggleKnob, {Position = targetPos}, 0.2)
        if callback then callback(state) end
    end
    
    toggleBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateToggle(not state)
        end
    end)
    
    updateToggle(defaultState)
    return {setValue = updateToggle, getValue = function() return state end}
end

function Components:Slider(parent, labelText, min, max, defaultVal, callback)
    local frame = Utility:Create("Frame", {
        Size = UDim2.new(0, 250, 0, 50),
        BackgroundTransparency = 1
    }, parent)
    
    local label = Utility:Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = labelText .. ": " .. tostring(defaultVal),
        TextColor3 = Color3.fromRGB(220, 220, 220),
        TextSize = 13,
        Font = Enum.Font.Gotham
    }, frame)
    
    local sliderBg = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 0, 4),
        Position = UDim2.new(0, 0, 0, 30),
        BackgroundColor3 = Color3.fromRGB(70, 75, 80),
        BorderSizePixel = 0
    }, frame)
    
    local sliderFill = Utility:Create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(230, 126, 34),
        BorderSizePixel = 0
    }, sliderBg)
    
    local knob = Utility:Create("TextButton", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0, 0, 0, -4),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Text = ""
    }, sliderBg)
    
    local value = defaultVal
    local dragging = false
    
    local function updateFromPosition(inputPos)
        local relX = math.clamp((inputPos.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * relX
        value = math.floor(value * 100) / 100
        local percent = (value - min) / (max - min)
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -6, 0, -4)
        label.Text = labelText .. ": " .. tostring(value)
        if callback then callback(value) end
    end
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateFromPosition(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateFromPosition(input)
        end
        if input.UserInputState == Enum.UserInputState.End then
            dragging = false
        end
    end)
    
    updateFromPosition({X = sliderBg.AbsolutePosition.X + (defaultVal - min)/(max - min) * sliderBg.AbsoluteSize.X})
    
    return {setValue = function(v) updateFromPosition({X = sliderBg.AbsolutePosition.X + (v - min)/(max - min) * sliderBg.AbsoluteSize.X}) end}
end

function Components:Dropdown(parent, labelText, options, multiSelect, defaultValues, callback)
    local frame = Utility:Create("Frame", {
        Size = UDim2.new(0, 200, 0, 36),
        BackgroundTransparency = 1
    }, parent)
    
    local label = Utility:Create("TextLabel", {
        Size = UDim2.new(0, 80, 1, 0),
        BackgroundTransparency = 1,
        Text = labelText,
        TextColor3 = Color3.fromRGB(220, 220, 220),
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left
    }, frame)
    
    local dropdownBtn = Utility:Create("TextButton", {
        Size = UDim2.new(0, 110, 1, 0),
        Position = UDim2.new(0, 80, 0, 0),
        BackgroundColor3 = Color3.fromRGB(45, 50, 55),
        Text = defaultValues and (multiSelect and #defaultValues .. " selected" or defaultValues[1]) or "Select",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0
    }, frame)
    
    local dropdownList = Utility:Create("Frame", {
        Size = UDim2.new(0, 110, 0, 0),
        Position = UDim2.new(0, 80, 0, 36),
        BackgroundColor3 = Color3.fromRGB(40, 45, 50),
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Visible = false
    }, frame)
    
    local listLayout = Utility:Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2)
    }, dropdownList)
    
    local selected = defaultValues or {}
    local buttons = {}
    
    local function updateDisplay()
        if multiSelect then
            dropdownBtn.Text = #selected == 0 and "Select" or (#selected .. " selected")
        else
            dropdownBtn.Text = selected[1] or "Select"
        end
        if callback then callback(multiSelect and selected or selected[1]) end
    end
    
    local function createOption(opt)
        local btn = Utility:Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundColor3 = Color3.fromRGB(45, 50, 55),
            Text = opt,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextSize = 12,
            Font = Enum.Font.Gotham,
            BorderSizePixel = 0
        }, dropdownList)
        
        local function toggleSelect()
            if multiSelect then
                local idx = table.find(selected, opt)
                if idx then
                    table.remove(selected, idx)
                    btn.BackgroundColor3 = Color3.fromRGB(45, 50, 55)
                else
                    table.insert(selected, opt)
                    btn.BackgroundColor3 = Color3.fromRGB(230, 126, 34)
                end
            else
                selected = {opt}
                updateDisplay()
                dropdownList.Visible = false
                for _, b in pairs(buttons) do
                    b.BackgroundColor3 = Color3.fromRGB(45, 50, 55)
                end
            end
            updateDisplay()
        end
        
        if multiSelect and table.find(selected, opt) then
            btn.BackgroundColor3 = Color3.fromRGB(230, 126, 34)
        end
        
        btn.MouseButton1Click:Connect(toggleSelect)
        return btn
    end
    
    for _, opt in pairs(options) do
        table.insert(buttons, createOption(opt))
    end
    
    local expanded = false
    dropdownBtn.MouseButton1Click:Connect(function()
        expanded = not expanded
        dropdownList.Visible = true
        local targetHeight = #options * 30
        Utility:Tween(dropdownList, {Size = UDim2.new(0, 110, 0, expanded and targetHeight or 0)}, 0.25)
        if not expanded then
            task.wait(0.25)
            dropdownList.Visible = false
        end
    end)
    
    updateDisplay()
    return {setSelected = function(vals) selected = vals; updateDisplay() end}
end

